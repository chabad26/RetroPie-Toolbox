#!/usr/bin/env python3

from pathlib import Path
import os
import subprocess

HOME = Path.home()
ROOT = HOME / "Documents/save_retropie"
MANUELS = ROOT / "Manuels"

def clear():
    os.system("clear")

def pause():
    input("\nAppuie sur Entrée pour revenir au menu...")

def run(cmd):
    print("\nCommande :")
    print(" ".join(map(str, cmd)))
    print()
    try:
        subprocess.call([str(x) for x in cmd])
    except KeyboardInterrupt:
        print("\nInterruption demandée.")

def yesno(question):
    return input(f"{question} [o/N] : ").strip().lower() in ("o", "oui", "y", "yes")

def title(text):
    clear()
    print("═══════════════════════════════════════════════")
    print(f"        {text}")
    print("═══════════════════════════════════════════════")
    print()

def manuals_menu():
    while True:
        title("Manuels")
        print("1) Moissonneuse V3 Cute")
        print("2) Contrôle qualité")
        print("3) Résumé qualité")
        print("4) Optimiser PDF lourds")
        print("5) Mettre à jour gamelists depuis PDF")
        print("0) Retour\n")

        c = input("Choix : ").strip()

        if c == "1":
            cmd = [MANUELS / "scripts/moissonner-manuels-v3-cute.py", "--choose"]
            if yesno("Télécharger réellement ?"):
                cmd.append("--download")
            else:
                cmd.append("--debug")
            sleep = input("Pause entre requêtes [4] : ").strip() or "4"
            cmd += ["--sleep", sleep]
            run(cmd); pause()

        elif c == "2":
            cmd = [MANUELS / "scripts/check-manuels.py", "--only-problems"]
            if yesno("Vérifier les gamelists ?"):
                cmd.append("--check-gamelists")
            run(cmd); pause()

        elif c == "3":
            run([MANUELS / "scripts/resume-qualite-manuels.py", "--limit", "20"]); pause()

        elif c == "4":
            optimize_menu()

        elif c == "5":
            system = input("Console à mettre à jour, vide = toutes : ").strip()
            cmd = [MANUELS / "scripts/update-gamelists-manuals-from-pdfs.py"]
            if system:
                cmd.append(system)
            run(cmd); pause()

        elif c == "0":
            return

def optimize_menu():
    title("Optimisation PDF")
    print("1) Dry-run PDF problématiques > 50 Mo")
    print("2) Optimiser PDF problématiques > 50 Mo")
    print("3) Optimiser un fichier précis")
    print("0) Retour\n")

    c = input("Choix : ").strip()

    if c == "1":
        run([MANUELS / "scripts/optimize-manuels.py", "--only-problems", "--min-size", "50M", "--dry-run"]); pause()
    elif c == "2":
        if yesno("Confirmer optimisation réelle ?"):
            run([MANUELS / "scripts/optimize-manuels.py", "--only-problems", "--min-size", "50M"])
        pause()
    elif c == "3":
        path = input("Chemin PDF, ex: pdf/gba/Fichier.pdf : ").strip()
        if path:
            run([MANUELS / "scripts/optimize-manuels.py", path, "--quality", "ebook"])
        pause()

def system_menu():
    while True:
        title("Diagnostic")
        print("1) Diagnostic rapide")
        print("2) Diagnostic complet + dépendances + stats")
        print("3) Réparation simple + diagnostic")
        print("0) Retour\n")

        c = input("Choix : ").strip()

        if c == "1":
            run([ROOT / "scripts/check-retropie.py", "--no-quality"]); pause()
        elif c == "2":
            run([ROOT / "scripts/check-retropie.py", "--doctor", "--stats"]); pause()
        elif c == "3":
            if yesno("Lancer les réparations automatiques simples ?"):
                run([ROOT / "scripts/check-retropie.py", "--fix", "--doctor", "--stats"])
            pause()
        elif c == "0":
            return

def profiles_menu():
    title("Profils joueurs")
    print("Profils gérés : Lucas, Nolan, Océane, Oliv\n")
    print("Switch / Eden :")
    print(f"  {ROOT / 'switch_profiles'}\n")
    print("PS3 / RPCS3 :")
    print(f"  {ROOT / 'ps3_profiles'}\n")
    print("Xbox 360 / Xenia :")
    print(f"  {ROOT / 'xbox360_profiles'}\n")
    print("Le choix du profil se fait au lancement du jeu.")
    pause()

def main():
    while True:
        title("RetroPie Save Tools")
        print("1) Manuels")
        print("2) Diagnostic / réparation")
        print("3) Profils joueurs")
        print("4) Git status")
        print("0) Quitter\n")

        c = input("Choix : ").strip()

        if c == "1":
            manuals_menu()
        elif c == "2":
            system_menu()
        elif c == "3":
            profiles_menu()
        elif c == "4":
            run(["git", "-C", str(ROOT), "status", "--short"]); pause()
        elif c == "0":
            print("À plus dans la forge RetroPie. 🌾")
            return
        else:
            pause()

if __name__ == "__main__":
    main()
